NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role (server-only) — required by webhooks and integrations sync engine
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Inbound webhooks
MULTICA_WEBHOOK_SECRET=change_me

# ============================================================
# Google Calendar integration (per-user OAuth 2.0)
# Setup: console.cloud.google.com -> enable Google Calendar API
# OAuth client (Web), redirect URIs:
#   http://localhost:3000/api/integrations/google/callback
#   https://<prod-domain>/api/integrations/google/callback
# Scope used: https://www.googleapis.com/auth/calendar
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# 32-byte random key (base64url) used to encrypt OAuth tokens at rest.
# Generate locally: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
INTEGRATIONS_ENC_KEY=

# Used to sign the OAuth state JWT (any random string, separate from above)
INTEGRATIONS_STATE_SECRET=

# Public base URL of the app (used to build links inside Google Calendar event descriptions)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Brief Client tokens
# Routes publiques /api/briefs/verify-token et /api/briefs/submit
# appelées en cross-origin depuis le site vitrine.
# ============================================================
# Origines autorisées par CORS (comma-separated, pas de slash final)
ALLOWED_ORIGINS=https://norva-corporate.fr,http://localhost:3001
# Base URL du site vitrine — utilisée pour construire les liens partagés
# aux prospects lors de la génération d'un token.
VITRINE_BASE_URL=https://norva-corporate.fr

# Notification email à la soumission d'un brief (MailerSend).
# Si une des trois variables manque, l'envoi est skip silencieusement
# (la soumission reste OK côté prospect).
#
# MailerSend free tier = 3000 emails/mois, multi-domaines autorisés.
# Le `from` doit utiliser un domaine vérifié dans ton compte MailerSend
# (idéalement norva-corporate.fr ou norva.fr pour la cohérence de marque).
# Le `to` (BRIEF_NOTIFY_EMAIL) accepte n'importe quelle adresse.
MAILERSEND_API_KEY=mlsn.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BRIEF_FROM_EMAIL=hello@norva-corporate.fr
BRIEF_FROM_NAME=norva.
BRIEF_NOTIFY_EMAIL=norvagroupe@gmail.com

# Génération PDF côté Vercel : @sparticuz/chromium par défaut.
# Pour tester en local (Windows/macOS), pointer vers le Chrome installé :
#   Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
#   macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Si vide, l'app tentera @sparticuz/chromium (échec probable en local).
LOCAL_CHROMIUM_PATH=

# ============================================================
# DocuSeal — Signature électronique des contrats de prestation
# ============================================================
# Free tier cloud : 3 contrats/mois. Bascule self-hosted (Docker)
# possible sans changer une ligne de code, juste l'URL.
#   Cloud     : https://api.docuseal.com
#   Self-host : https://<ton-domaine>/api
#
# Setup (5 min) :
#   1. https://docuseal.com → Sign up
#   2. Settings → API → Generate New API Token → copier dans DOCUSEAL_API_KEY
#   3. Settings → Webhooks → Add Webhook
#        URL    : ${NEXT_PUBLIC_APP_URL}/api/webhooks/docuseal
#        Events : submission.completed, submission.expired, form.declined
#        Secret : générer un random (openssl rand -hex 32) et le coller
#                 ICI dans DOCUSEAL_WEBHOOK_SECRET et dans la conf webhook
#                 DocuSeal — c'est ce secret qui sert au HMAC-SHA256.
DOCUSEAL_API_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=

# Notifications post-signature (MailerSend, fallback sur BRIEF_* si vide).
# Si non défini, l'app utilise BRIEF_FROM_EMAIL / BRIEF_FROM_NAME /
# BRIEF_NOTIFY_EMAIL pour l'email interne. L'email client signataire
# utilise le même `from` ; aucune variable `to` car l'email est lu
# depuis client_snapshot.email du contrat.
CONTRAT_FROM_EMAIL=
CONTRAT_FROM_NAME=
CONTRAT_NOTIFY_EMAIL=

# ============================================================
# Gmail — Envoi des campagnes email (module Campagnes)
# Setup: console.cloud.google.com -> enable Gmail API
# OAuth client (Web), redirect URIs:
#   http://localhost:3000/api/auth/gmail/callback
#   https://<prod-domain>/api/auth/gmail/callback
# Scope used: https://www.googleapis.com/auth/gmail.send
# ============================================================
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback
