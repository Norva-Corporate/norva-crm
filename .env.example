NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role (server-only) — required by webhooks and integrations sync engine
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Inbound webhooks
MULTICA_WEBHOOK_SECRET=change_me

# ============================================================
# Google Calendar integration (per-user OAuth 2.0)
# Setup: console.cloud.google.com -> enable Google Calendar API
# OAuth client (Web), redirect URIs:
#   http://localhost:3000/api/integrations/google/callback
#   https://<prod-domain>/api/integrations/google/callback
# Scope used: https://www.googleapis.com/auth/calendar
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# 32-byte random key (base64url) used to encrypt OAuth tokens at rest.
# Generate locally: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
INTEGRATIONS_ENC_KEY=

# Used to sign the OAuth state JWT (any random string, separate from above)
INTEGRATIONS_STATE_SECRET=

# Public base URL of the app (used to build links inside Google Calendar event descriptions)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Brief Client tokens (Phase 1)
# Routes publiques /api/briefs/verify-token et /api/briefs/submit
# appelées en cross-origin depuis le site vitrine.
# ============================================================
# Origines autorisées par CORS (comma-separated, pas de slash final)
ALLOWED_ORIGINS=https://norva-corporate.fr,http://localhost:3001
# Base URL du site vitrine — utilisée pour construire les liens partagés
# aux prospects lors de la génération d'un token.
VITRINE_BASE_URL=https://norva-corporate.fr
